APP_NAME="Rent & Sales Platform"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173

# Optional: absolute path to SPA when web root is public_html/app/ (sibling of rent-sales/)
# SPA_INDEX_PATH=/home/rasulmar/public_html/app/index.html

# Production subdirectory example (https://rasulmart.com/app):
# APP_URL=https://rasulmart.com/app
# FRONTEND_URL=https://rasulmart.com
# SESSION_PATH=/app
# SESSION_DOMAIN=rasulmart.com
# SESSION_SECURE_COOKIE=true
# SANCTUM_STATEFUL_DOMAINS=rasulmart.com,www.rasulmart.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5433
DB_DATABASE=rent_sales
DB_USERNAME=rent_sales
DB_PASSWORD=rent_sales

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
# Leave empty for local dev so cookies work for both localhost and 127.0.0.1
SESSION_DOMAIN=
SANCTUM_STATEFUL_DOMAINS=localhost:5173,127.0.0.1:5173

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Production mail — pick ONE setup below (never commit passwords).

# Option A: cPanel mailbox (info@rasulmart.com on mail.rasulmart.com)
# MAIL_MAILER=smtp
# MAIL_SCHEME=smtps
# MAIL_HOST=mail.rasulmart.com
# MAIL_PORT=465
# MAIL_USERNAME=info@rasulmart.com
# MAIL_PASSWORD="your-cpanel-mailbox-password"
# MAIL_FROM_ADDRESS=info@rasulmart.com
# MAIL_FROM_NAME="${APP_NAME}"
# MAIL_EHLO_DOMAIN=rasulmart.com

# Option A alternate (STARTTLS — try if port 465 fails):
# MAIL_SCHEME=null
# MAIL_PORT=587

# Option B: Google Workspace (admin@rasulmart.com — requires app password)
# MAIL_MAILER=smtp
# MAIL_SCHEME=null
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USERNAME=admin@rasulmart.com
# MAIL_PASSWORD="your-16-char-google-app-password"
# MAIL_FROM_ADDRESS=admin@rasulmart.com
# MAIL_FROM_NAME="${APP_NAME}"

PASSWORD_RESET_CODE_TTL=15

# Comma-separated admin emails for operational alerts (draft charge batches, etc.)
# ADMIN_NOTIFICATION_EMAILS=admin@rasulmart.com,info@rasulmart.com

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Module currencies (documentation — sales UI uses utils/money.js defaults)
# SALES_CURRENCY=USD
# RENTAL_CURRENCY=KES
